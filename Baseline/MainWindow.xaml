<Window x:Class="BaseLine.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Baseline"
        Icon="Assets/Brand/baseline-mark.png"
        Width="1560"
        Height="980"
        MinWidth="1280"
        MinHeight="720"
        ResizeMode="CanResize"
        WindowStyle="None"
        Background="Transparent">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="{StaticResource WindowCornerRadius}"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6" />
    </shell:WindowChrome.WindowChrome>

    <Border Margin="0"
            CornerRadius="{StaticResource WindowCornerRadius}"
            Background="{StaticResource ShellSurfaceBrush}"
            BorderBrush="{StaticResource SurfaceBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
                <RowDefinition Height="0" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBackgroundBrush}"
                    CornerRadius="28,28,0,0"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="148" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="20,0,0,0">
                        <Border Width="34"
                                Height="34"
                                CornerRadius="10"
                                Background="#202B3B">
                            <Image Margin="5"
                                   Source="Assets/Brand/baseline-mark.png"
                                   Stretch="Uniform" />
                        </Border>
                        <TextBlock Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="Baseline"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="Capture. Compare. Replicate."
                               FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,18,0">
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                Content="-"
                                Click="MinimizeButton_OnClick" />
                        <Button Style="{StaticResource TitleBarButtonStyle}"
                                Content="[]"
                                Click="MaximizeButton_OnClick">
                        </Button>
                        <Button Style="{StaticResource TitleBarCloseButtonStyle}"
                                Content="x"
                                Click="CloseButton_OnClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Margin="0"
                        Padding="18,18,16,18"
                        Background="{StaticResource SidebarBackgroundBrush}"
                        BorderBrush="{StaticResource SoftBorderBrush}"
                        BorderThickness="0,0,1,0"
                        CornerRadius="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="4,4,4,22">
                            <TextBlock Text="Workspace"
                                       Foreground="#94A3B8"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="Baseline"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="SemiBold" />
                        </StackPanel>

                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding NavigationItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding SelectCommand}"
                                            Style="{StaticResource NavigationButtonStyle}">
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                   FontSize="15.5"
                                                   FontWeight="SemiBold" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Grid.Row="2"
                                Margin="4,16,4,4"
                                Padding="14,12"
                                Background="#111827"
                                BorderBrush="#28364B"
                                BorderThickness="1"
                                CornerRadius="{StaticResource ControlCornerRadius}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="9"
                                         Height="9"
                                         Margin="0,3,10,0"
                                         VerticalAlignment="Top"
                                         Fill="#2DD4BF" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding StatusText}"
                                           Foreground="#CBD5E1"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Margin="22"
                        Padding="26"
                        Background="{StaticResource TransparentBrush}"
                        BorderThickness="0"
                        CornerRadius="{StaticResource CardCornerRadius}">
                    <ContentControl x:Name="PageHost"
                                    Content="{Binding CurrentPage}"
                                    Opacity="1" />
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Background="#0F141D"
                    CornerRadius="0,0,28,28">
                <TextBlock Margin="20,0"
                           VerticalAlignment="Center"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource MutedTextBrush}" />
            </Border>
        </Grid>
    </Border>
</Window>
