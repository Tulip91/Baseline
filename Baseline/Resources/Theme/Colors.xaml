<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowStartColor">#050814</Color>
    <Color x:Key="WindowEndColor">#0D1430</Color>
    <Color x:Key="ShellSurfaceStartColor">#10151C</Color>
    <Color x:Key="ShellSurfaceEndColor">#151B24</Color>
    <Color x:Key="TitleBarStartColor">#131820</Color>
    <Color x:Key="TitleBarEndColor">#171E28</Color>
    <Color x:Key="SidebarStartColor">#0B1020</Color>
    <Color x:Key="SidebarEndColor">#111927</Color>
    <Color x:Key="PanelStartColor">#171E28</Color>
    <Color x:Key="PanelEndColor">#111820</Color>
    <Color x:Key="PanelAltStartColor">#121922</Color>
    <Color x:Key="PanelAltEndColor">#0E141D</Color>
    <Color x:Key="InputStartColor">#111821</Color>
    <Color x:Key="InputEndColor">#151D28</Color>
    <Color x:Key="BorderColor">#2B3444</Color>
    <Color x:Key="BorderSoftColor">#253041</Color>
    <Color x:Key="AccentColor">#7C3AED</Color>
    <Color x:Key="AccentHoverColor">#8B5CF6</Color>
    <Color x:Key="AccentPressedColor">#6D28D9</Color>
    <Color x:Key="AccentMutedColor">#241A3A</Color>
    <Color x:Key="AccentGlowColor">#A78BFA</Color>
    <Color x:Key="PrimaryTextColor">#F8FAFC</Color>
    <Color x:Key="SecondaryTextColor">#CBD5E1</Color>
    <Color x:Key="MutedTextColor">#94A3B8</Color>
    <Color x:Key="DisabledTextColor">#64748B</Color>
    <Color x:Key="SuccessColor">#4ADE80</Color>
    <Color x:Key="WarningColor">#FACC15</Color>
    <Color x:Key="DangerColor">#FB7185</Color>
    <Color x:Key="OverlayColor">#A6000000</Color>

    <CornerRadius x:Key="WindowCornerRadius">24</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="CompactCornerRadius">8</CornerRadius>
    <Thickness x:Key="CardBorderThickness">1</Thickness>

    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource WindowStartColor}" Offset="0" />
        <GradientStop Color="{StaticResource WindowEndColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ShellSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource ShellSurfaceStartColor}" Offset="0" />
        <GradientStop Color="{StaticResource ShellSurfaceEndColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="TitleBarBackgroundBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource TitleBarStartColor}" Offset="0" />
        <GradientStop Color="{StaticResource TitleBarEndColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SidebarBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource SidebarStartColor}" Offset="0" />
        <GradientStop Color="{StaticResource SidebarEndColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PanelBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource PanelStartColor}" Offset="0" />
        <GradientStop Color="{StaticResource PanelEndColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PanelBackgroundAltBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource PanelAltStartColor}" Offset="0" />
        <GradientStop Color="{StaticResource PanelAltEndColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="InputBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource InputStartColor}" Offset="0" />
        <GradientStop Color="{StaticResource InputEndColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ButtonBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0B7CFF" Offset="0" />
        <GradientStop Color="{StaticResource AccentColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ButtonHoverBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2491FF" Offset="0" />
        <GradientStop Color="{StaticResource AccentHoverColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ButtonPressedBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2563EB" Offset="0" />
        <GradientStop Color="{StaticResource AccentPressedColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SecondaryButtonBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1A2230" Offset="0" />
        <GradientStop Color="#202A3A" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SecondaryButtonHoverBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#202B3B" Offset="0" />
        <GradientStop Color="#263246" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="NavigationSelectedBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#172A49" Offset="0" />
        <GradientStop Color="#271E52" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource DisabledTextColor}" />
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="SoftBorderBrush" Color="{StaticResource BorderSoftColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMutedColor}" />
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlowColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}" />
    <SolidColorBrush x:Key="TransparentBrush" Color="#00FFFFFF" />

    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
</ResourceDictionary>
