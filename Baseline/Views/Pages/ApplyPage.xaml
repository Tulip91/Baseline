<UserControl x:Class="BaseLine.Views.Pages.ApplyPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <TextBlock Text="Replicate"
                   Style="{StaticResource HeaderTitleTextStyle}" />

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,18,0,18">
            <Button Content="Select All"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding SelectAllCommand}" />
            <Button Margin="12,0,0,0"
                    Content="Mismatches"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding SelectMismatchesCommand}" />
            <Button Margin="12,0,0,0"
                    Content="Clear"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding ClearSelectionCommand}" />
            <Button Margin="12,0,0,0"
                    Content="Replicate"
                    Command="{Binding ApplySelectedCommand}" />
        </StackPanel>

        <Border Grid.Row="2"
                Style="{StaticResource SectionCardStyle}"
                Margin="0"
                Padding="0">
            <DataGrid ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Use"
                                            Binding="{Binding IsSelected, Mode=TwoWay}" Width="70" />
                    <DataGridTextColumn Header="Category"
                                        Binding="{Binding Item.Category}" Width="115" />
                    <DataGridTextColumn Header="Item"
                                        Binding="{Binding Item.DisplayName}" Width="220" />
                    <DataGridTextColumn Header="Current"
                                        Binding="{Binding Item.CurrentValue}" Width="220" />
                    <DataGridTextColumn Header="Target"
                                        Binding="{Binding Item.ProfileValue}" Width="220" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Item.Status}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,16,0,0"
                Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Results"
                           Style="{StaticResource SectionHeaderTextStyle}" />
                <ListBox Grid.Row="1"
                         Margin="0,14,0,0"
                         ItemsSource="{Binding Results}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding Message}"
                                           Style="{StaticResource MutedLabelTextStyle}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
