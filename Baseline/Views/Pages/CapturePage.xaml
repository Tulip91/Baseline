<UserControl x:Class="BaseLine.Views.Pages.CapturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="clr-namespace:BaseLine.Core"
             mc:Ignorable="d">
    <UserControl.Resources>
        <x:Array x:Key="RegistryRoots" Type="{x:Type core:RegistryRoot}">
            <core:RegistryRoot>CurrentUser</core:RegistryRoot>
            <core:RegistryRoot>LocalMachine</core:RegistryRoot>
        </x:Array>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <StackPanel>
                <TextBlock Text="Snapshot Workspace"
                           Style="{StaticResource HeaderTitleTextStyle}" />
                <TextBlock Margin="0,6,0,0"
                           Text="Capture the current machine into a reusable baseline."
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="13.5" />
            </StackPanel>

            <StackPanel Margin="0,22,0,0"
                        Orientation="Horizontal">
                <Button Width="230"
                        Height="58"
                        Content="Capture Snapshot"
                        Command="{Binding CaptureCommand}" />
                <Button Margin="14,0,0,0"
                        Width="142"
                        Height="58"
                        Content="Compare"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1"
              Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="720" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <UniformGrid Columns="3"
                             Margin="0,0,0,18">
                    <Border Style="{StaticResource SectionCardStyle}"
                            Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Categories"
                                       Style="{StaticResource MutedLabelTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding SelectedCategoryCount}"
                                       FontSize="28"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SectionCardStyle}"
                            Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Registry"
                                       Style="{StaticResource MutedLabelTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding SelectedRegistryTemplateCount}"
                                       FontSize="28"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SectionCardStyle}"
                            Margin="0">
                        <StackPanel>
                            <TextBlock Text="Policies"
                                       Style="{StaticResource MutedLabelTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding SelectedPolicyTemplateCount}"
                                       FontSize="28"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="1"
                        Style="{StaticResource SectionCardStyle}"
                        Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Capture Scope"
                                       Style="{StaticResource SectionHeaderTextStyle}" />
                            <TextBlock Grid.Column="1"
                                       Text="Selected"
                                       Foreground="{StaticResource AccentGlowBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                        </Grid>

                        <ItemsControl Grid.Row="1"
                                      Margin="0,18,0,0"
                                      ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,12,12"
                                            MinHeight="78"
                                            Padding="16,12"
                                            Background="{StaticResource InputBackgroundBrush}"
                                            BorderBrush="{StaticResource SoftBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource ControlCornerRadius}">
                                        <CheckBox Margin="0"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding IsSelected}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding Description}"
                                                           Style="{StaticResource MutedLabelTextStyle}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Grid.Row="2"
                              Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2"
                                    Width="150"
                                    Content="Save Baseline"
                                    Command="{Binding CaptureCommand}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Baseline Readiness"
                                   Style="{StaticResource SectionHeaderTextStyle}" />

                        <StackPanel Grid.Row="1"
                                    Margin="0,18,0,0"
                                    Orientation="Horizontal">
                            <StackPanel Width="90">
                                <TextBlock Text="Adapters"
                                           Style="{StaticResource MutedLabelTextStyle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding AdapterCount}"
                                           FontSize="24"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Mode"
                                           Style="{StaticResource MutedLabelTextStyle}" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="JSON"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Margin="0,20,0,0">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Rollback metadata"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="Ready"
                                           Foreground="{StaticResource SuccessBrush}" />
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Compare report"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="After capture"
                                           Foreground="{StaticResource WarningBrush}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Apply plan"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="Selective"
                                           Foreground="{StaticResource AccentGlowBrush}" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource SectionCardStyle}"
                        Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Registry + Policy"
                                       Style="{StaticResource SectionHeaderTextStyle}" />
                            <TextBlock Grid.Column="1"
                                       Text="Curated"
                                       Foreground="{StaticResource AccentGlowBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,16,0,0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock Text="Registry Tweaks"
                                           Style="{StaticResource MutedLabelTextStyle}" />
                                <ListBox Margin="0,8,0,14"
                                         MaxHeight="160"
                                         ItemsSource="{Binding RegistryTemplates}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding IsSelected}" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Template.DisplayName}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               Text="{Binding Template.GroupName}"
                                                               Foreground="{StaticResource AccentGlowBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="Policies"
                                           Style="{StaticResource MutedLabelTextStyle}" />
                                <ListBox Margin="0,8,0,0"
                                         MaxHeight="118"
                                         ItemsSource="{Binding PolicyTemplates}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding IsSelected}" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Template.DisplayName}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               Text="{Binding Template.GroupName}"
                                                               Foreground="{StaticResource AccentGlowBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>

                        <Button Grid.Row="2"
                                Margin="0,14,0,0"
                                Content="Detect Network"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RefreshAdaptersCommand}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
