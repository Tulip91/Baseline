<UserControl x:Class="BaseLine.Views.Pages.CapturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="clr-namespace:BaseLine.Core"
             mc:Ignorable="d">
    <UserControl.Resources>
        <x:Array x:Key="RegistryRoots" Type="{x:Type core:RegistryRoot}">
            <core:RegistryRoot>CurrentUser</core:RegistryRoot>
            <core:RegistryRoot>LocalMachine</core:RegistryRoot>
        </x:Array>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Capture"
                   Style="{StaticResource HeaderTitleTextStyle}" />

        <ScrollViewer Grid.Row="1"
                      Margin="0,20,0,18"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="330" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource SectionCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Profile"
                                       Style="{StaticResource SectionHeaderTextStyle}" />
                            <TextBox Grid.Row="1"
                                     Margin="0,14,0,0"
                                     Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Categories"
                                       Style="{StaticResource SectionHeaderTextStyle}" />
                            <ItemsControl Margin="0,16,0,0"
                                          ItemsSource="{Binding Categories}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,10,10"
                                                MinHeight="72"
                                                Padding="14,12"
                                                Background="{StaticResource PanelBackgroundBrush}"
                                                BorderBrush="{StaticResource SoftBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource ControlCornerRadius}">
                                            <CheckBox Margin="0"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding IsSelected}">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           TextWrapping="Wrap" />
                                            </CheckBox>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="Network"
                                           Style="{StaticResource SectionHeaderTextStyle}"
                                           DockPanel.Dock="Left" />
                                <Button Content="Detect"
                                        Width="116"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding RefreshAdaptersCommand}"
                                        DockPanel.Dock="Right" />
                            </DockPanel>
                            <ListBox Grid.Row="1"
                                     Margin="0,14,0,0"
                                     ItemsSource="{Binding ActiveAdapters}"
                                     SelectedItem="{Binding SelectedAdapter}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding Description}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource MutedLabelTextStyle}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SectionCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Registry Tweaks"
                                       Style="{StaticResource SectionHeaderTextStyle}" />
                            <ListBox Grid.Row="1"
                                     Margin="0,16,0,0"
                                     MaxHeight="360"
                                     ItemsSource="{Binding RegistryTemplates}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{Binding IsSelected}" />
                                            <Grid Grid.Column="1">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="{Binding Template.DisplayName}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Row="1"
                                                           Margin="0,3,0,0"
                                                           Text="{Binding Template.GroupName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource AccentBrush}" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Grid Grid.Row="2"
                                  Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="116" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          MinWidth="116"
                                          ItemsSource="{StaticResource RegistryRoots}"
                                          SelectedItem="{Binding CustomRegistryRoot}" />
                                <TextBox Grid.Column="1"
                                         Margin="10,0,0,0"
                                         Text="{Binding CustomRegistryPath, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="2"
                                         Margin="10,0,0,0"
                                         Text="{Binding CustomRegistryValueName, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="3"
                                        Margin="10,0,0,0"
                                        Content="Add"
                                        Command="{Binding AddRegistryEntryCommand}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Policies"
                                       Style="{StaticResource SectionHeaderTextStyle}" />
                            <ListBox Grid.Row="1"
                                     Margin="0,16,0,0"
                                     MaxHeight="300"
                                     ItemsSource="{Binding PolicyTemplates}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{Binding IsSelected}" />
                                            <Grid Grid.Column="1">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="{Binding Template.DisplayName}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Row="1"
                                                           Margin="0,3,0,0"
                                                           Text="{Binding Template.GroupName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource AccentBrush}" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Grid Grid.Row="2"
                                  Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="116" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          MinWidth="116"
                                          ItemsSource="{StaticResource RegistryRoots}"
                                          SelectedItem="{Binding CustomPolicyRoot}" />
                                <TextBox Grid.Column="1"
                                         Margin="10,0,0,0"
                                         Text="{Binding CustomPolicyPath, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="2"
                                         Margin="10,0,0,0"
                                         Text="{Binding CustomPolicyValueName, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="3"
                                        Margin="10,0,0,0"
                                        Content="Add"
                                        Command="{Binding AddPolicyEntryCommand}" />
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Padding="10,8"
                Background="{StaticResource TransparentBrush}"
                CornerRadius="{StaticResource CardCornerRadius}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Width="180"
                        Content="Capture Profile"
                        Command="{Binding CaptureCommand}" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
