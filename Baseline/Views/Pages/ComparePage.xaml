<UserControl x:Class="BaseLine.Views.Pages.ComparePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Compare"
                   Style="{StaticResource HeaderTitleTextStyle}" />

        <Grid Grid.Row="1"
              Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="196" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Content="Run Compare"
                    Command="{Binding RunCompareCommand}" />
            <ComboBox Grid.Column="1"
                      Margin="12,0,0,0"
                      ItemsSource="{Binding CategoryFilters}"
                      SelectedItem="{Binding SelectedCategoryFilter}" />
            <CheckBox Grid.Column="2"
                      Margin="14,8,0,0"
                      Content="Only mismatches"
                      IsChecked="{Binding ShowOnlyMismatches}" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <UniformGrid Columns="4"
                         Margin="0,0,0,14">
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Ready"
                                   Style="{StaticResource MutedLabelTextStyle}" />
                        <TextBlock Text="{Binding Summary.ReadyCount}"
                                   FontSize="30"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Matches"
                                   Style="{StaticResource MutedLabelTextStyle}" />
                        <TextBlock Text="{Binding Summary.MatchedCount}"
                                   FontSize="30"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Warnings"
                                   Style="{StaticResource MutedLabelTextStyle}" />
                        <TextBlock Text="{Binding Summary.WarningCount}"
                                   FontSize="30"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Unsupported"
                                   Style="{StaticResource MutedLabelTextStyle}" />
                        <TextBlock Text="{Binding Summary.UnsupportedCount}"
                                   FontSize="30"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="1"
                    Style="{StaticResource SectionCardStyle}"
                    Margin="0"
                    Padding="0">
                <DataGrid ItemsSource="{Binding RowsView}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Category"
                                            Binding="{Binding Item.Category}" Width="110" />
                        <DataGridTextColumn Header="Group"
                                            Binding="{Binding Item.GroupName}" Width="130" />
                        <DataGridTextColumn Header="Item"
                                            Binding="{Binding Item.DisplayName}" Width="190" />
                        <DataGridTextColumn Header="Profile"
                                            Binding="{Binding Item.ProfileValue}" Width="180" />
                        <DataGridTextColumn Header="Current"
                                            Binding="{Binding Item.CurrentValue}" Width="180" />
                        <DataGridTextColumn Header="Action"
                                            Binding="{Binding Item.RecommendedAction}" Width="180" />
                        <DataGridTextColumn Header="Safety"
                                            Binding="{Binding Item.SafetyLevel}" Width="90" />
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Item.Status}" Width="120" />
                        <DataGridTextColumn Header="Notes"
                                            Binding="{Binding Item.Notes}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
