<UserControl x:Class="BaseLine.Views.Pages.RollbackPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Rollback"
                   Style="{StaticResource HeaderTitleTextStyle}" />

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,18,0,18">
            <Button Content="Refresh"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding RefreshHistoryCommand}" />
            <Button Margin="12,0,0,0"
                    Content="Restore"
                    Command="{Binding RollbackSelectedCommand}" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Sessions"
                               Style="{StaticResource SectionHeaderTextStyle}" />
                    <ListBox Grid.Row="1"
                             Margin="0,14,0,0"
                             ItemsSource="{Binding Records}"
                             SelectedItem="{Binding SelectedRecord}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding ProfileName}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding CreatedAt}"
                                               Style="{StaticResource MutedLabelTextStyle}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding SessionId}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Contents"
                               Style="{StaticResource SectionHeaderTextStyle}" />
                    <ListBox Grid.Row="1"
                             Margin="0,14,0,0"
                             ItemsSource="{Binding Items}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding Subtitle}"
                                               Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding Detail}"
                                               Style="{StaticResource MutedLabelTextStyle}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
